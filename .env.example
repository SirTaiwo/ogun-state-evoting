# Copy this file to ".env" and change the secrets before any real use.
PORT=3000

# Secret used to sign login tokens (JWT). Use a long random string.
JWT_SECRET=replace_with_a_long_random_secret

# Salt used to derive the anonymous per-election voter hash (ballot secrecy).
VOTE_SALT=replace_with_another_long_random_secret

# Optional: path to the SQLite database file.
# DB_PATH=./evoting.db
